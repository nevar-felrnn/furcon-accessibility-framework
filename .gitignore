# ── Conventions folder ────────────────────────────────────
# Convention-specific YAML files contain private data and
# must never be committed to this public repo.
#
# conventions/template/convention.yaml IS committed — it's
# the public template, not a real convention's private data.
# conventions/sample/convention.yaml IS committed — it's a
# working example with generic placeholder values, no real data.
# Everything else in conventions/ is ignored.
conventions/**/*.yaml
conventions/**/*.yml
!conventions/template/convention.yaml
!conventions/sample/convention.yaml
conventions/*/notes/

# ── Output files ──────────────────────────────────────────
# Assembled outputs contain private convention-specific
# information. Never commit them to the public repo.
output/
test-output/

# ── Extra safety net ──────────────────────────────────────
private/

# ── OS and editor files ───────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini
*.swp
*.swo
*~
.idea/
.vscode/
*.sublime-project
*.sublime-workspace

# ── Python ────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
.Python
*.egg-info/
dist/
build/
venv/
.env

# ── AI ────────────────────────────────────────────────────
.claude/
